        "format": "table",
        "rawQuery": true,
        "rawSql": "WITH last_1000_global AS (\n    SELECT\n        cat_id,\n        fraud_flag\n    FROM scores\n    WHERE cat_id IS NOT NULL\n    ORDER BY created_at DESC\n    LIMIT 1000\n)\nSELECT\n    cat_id AS \"Категория\",\n    AVG(fraud_flag)::float AS \"Доля фрода\"\nFROM last_1000_global\nGROUP BY cat_id\nORDER BY \"Доля фрода\" DESC;",
        "refId": "A"
      }
    ],
    "title": "Доля фрода по категориям (1000 последних транзакций)",
