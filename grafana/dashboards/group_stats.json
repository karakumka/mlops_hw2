          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
         "rawSql": "WITH filtered_scores AS (\n    SELECT score\n    FROM scores\n    WHERE score IS NOT NULL\n      AND us_state LIKE ANY(ARRAY[${us_state:singlequote}])\n      AND merch LIKE ANY(ARRAY[${merch:sqlstring}])\n), bins AS (\n    SELECT\n        width_bucket(score, 0, 1, 20) AS bin_id,\n        COUNT(*) AS cnt\n    FROM filtered_scores\n    GROUP BY width_bucket(score, 0, 1, 20)\n), total AS (\n    SELECT SUM(cnt) AS total_cnt\n    FROM bins\n)\nSELECT\n    CONCAT(\n        ROUND(((bin_id - 1) * 0.05)::numeric, 2),\n        '-',\n        ROUND((bin_id * 0.05)::numeric, 2)\n    ) AS score_bin,\n    cnt::float / NULLIF(total_cnt, 0) AS density\nFROM bins, total\nWHERE bin_id BETWEEN 1 AND 20\nORDER BY bin_id;",
          "refId": "A"
        }
      ],
      "title": "Плотность распределения скоров",
      "type": "barchart"
